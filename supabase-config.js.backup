function getUser() {
    return window.currentUser;
}

function isAuthenticated() {
    return window.currentUser !== null;
}

// Registration
async function registerUser(email, password, fullName) {
    const client = getClient();
    if (!client) throw new Error('Supabase not initialized');

    const { data, error } = await client.auth.signUp({
        email,
        password,
        options: {
            data: {
                full_name: fullName
            }
        }
    });

    if (error) throw error;
    return data;
}

// Login
async function loginUser(email, password) {
    const client = getClient();
    if (!client) throw new Error('Supabase not initialized');

    const { data, error } = await client.auth.signInWithPassword({
        email,
        password
    });

    if (error) throw error;
    return data;
}

// Logout
async function logoutUser() {
    const client = getClient();
    if (!client) throw new Error('Supabase not initialized');

    const { error } = await client.auth.signOut();
    if (error) throw error;
}

// Reset password
async function resetPassword(email) {
    const client = getClient();
    if (!client) throw new Error('Supabase not initialized');

    const { error } = await client.auth.resetPasswordForEmail(email, {
        redirectTo: window.location.origin + '/reset-password'
    });

    if (error) throw error;
}

// Get current user profile
async function getUserProfile() {
    const client = getClient();
    const user = getCurrentUser();
    if (!client || !user) return null;

    try {
        const { data, error } = await client
            .from('profiles')
            .select('*')
            .eq('id', user.id)
            .single();

        if (error) {
            console.error('Profile fetch error:', error);
            return null;
        }
        return data;
    } catch (err) {
        console.error('Get profile error:', err);
        return null;
    }
}

// Get user's bookings
async function getUserBookings(limit = 10) {
    const client = getClient();
    const user = getCurrentUser();
    if (!client || !user) return [];

    try {
        const { data, error } = await client
            .from('bookings')
            .select(`
                id,
                table_id,
                customer_name,
                customer_phone,
                date,
                time_slot,
                guests_count,
                comment,
                status,
                created_at,
                tables (
                    number,
                    seats,
                    zone_name
                )
            `)
            .eq('user_id', user.id)
            .order('date', { ascending: false })
            .order('created_at', { ascending: false })
            .limit(limit);

        if (error) {
            console.error('Error fetching user bookings:', error);
            return [];
        }

        return data;
    } catch (err) {
        console.error('Get bookings error:', err);
        return [];
    }
}

// Update user profile
async function updateUserProfile(profileData) {
    const client = getClient();
    const user = getCurrentUser();
    if (!client || !user) throw new Error('Not authenticated');

    const { data, error } = await client
        .from('profiles')
        .update({
            ...profileData,
            updated_at: new Date().toISOString()
        })
        .eq('id', user.id);

    if (error) {
        console.error('Update profile error:', error);
        throw error;
    }
    return data;
}

// Ensure user profile exists (create if missing)
async function ensureUserProfile(user) {
    const client = getClient();
    if (!client || !user) {
        console.log('ensureUserProfile: no client or user');
        return false;
    }

    try {
        console.log('Checking profile for user:', user.id);
        const { data, error } = await client
            .from('profiles')
            .select('id')
            .eq('id', user.id)
            .single();

        if (error) {
            console.log('Profile select error:', error.message);
        }

        if (data) {
            console.log('Profile exists');
            return true;
        }

        console.log('Profile not found, creating...');
        const { data: insertData, error: insertError } = await client
            .from('profiles')
            .insert({
                id: user.id,
                email: user.email,
                full_name: user.user_metadata?.full_name || user.email.split('@')[0],
                phone: null
            });

        if (insertError) {
            console.error('Profile insert error:', insertError);
            return false;
        }

        console.log('Profile created:', insertData);
        return true;
    } catch (e) {
        console.error('Ensure profile exception:', e);
        return false;
    }
}
