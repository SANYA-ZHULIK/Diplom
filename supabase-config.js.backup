const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inhid2ZyZm5hZ2VzY2Vlb3phemNyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUyMDcyODEsImV4cCI6MjA5MDc4MzI4MX0.B86Ma5hwPRHlV5bUG7ULGA0B_qeObt6imTkF0WJo_LQ';

window.supabaseClient = null;
window.currentUser = null;
window.authLoading = true;

// Determine storage key based on page
function getStorageKey() {
    const path = window.location.pathname;
    if (path.includes('booking-manager') || path.includes('admin')) {
        return 'supabase-auth-admin-panel';
    }
    return 'supabase-auth-main-site';
}

function initSupabase(callback) {
    function tryInit() {
        try {
            console.log('Supabase init attempt, window.supabase:', !!window.supabase, 'path:', window.location.pathname);
            if (window.supabase) {
                const storageKey = getStorageKey();
                console.log('Initializing Supabase with storageKey:', storageKey);
                
                window.supabaseClient = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
                    auth: {
                        storage: window.localStorage,
                        storageKey: storageKey,
                        persistSession: true,
                        autoRefreshToken: true,
                        detectSessionInUrl: false
                    }
                });

                window.supabaseClient.auth.getSession().then(({ data: { session } }) => {
                    window.currentUser = session?.user ?? null;
                    window.authLoading = false;
                    console.log('Session loaded for:', window.currentUser?.email);
                    if (callback) callback(window.supabaseClient, session);
                });

                window.supabaseClient.auth.onAuthStateChange((event, session) => {
                    window.currentUser = session?.user ?? null;
                    window.authLoading = false;
                    console.log('Auth state change:', event, window.currentUser?.email);
                    window.dispatchEvent(new CustomEvent('auth-state-change', {
                        detail: { event, user: window.currentUser, session }
                    }));
                    if (event === 'SIGNED_OUT' && !window.location.pathname.includes('booking-manager')) {
                        window.location.href = '/';
                    }
                });
            } else {
                setTimeout(tryInit, 300);
            }
        } catch (err) {
            console.error('Supabase init error:', err);
            setTimeout(tryInit, 300);
        }
    }
    tryInit();
}

// Also try init immediately (in case supabase script loads later)
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
        // Skip auto-init on admin page, let admin-panel handle it
        const path = window.location.pathname;
        if (!path.includes('booking-manager')) {
            setTimeout(initSupabase, 100);
        }
    });
} else {
    const path = window.location.pathname;
    if (!path.includes('booking-manager')) {
        setTimeout(initSupabase, 100);
    }
}

function getClient() {
    return window.supabaseClient;
}

function getCurrentUser() {
    return window.currentUser;
}

function getUser() {
    return window.currentUser;
}

function isAuthenticated() {
    return window.currentUser !== null;
}

function getCurrentUser() {
    return window.currentUser;
